import { useState, useEffect } from "react";
import { useToolInvocation } from "skybridge/web";

export default function CorrelationDashboard() {
  const [dateRange, setDateRange] = useState({ start: "2026-01-01", end: "2026-06-30" });
  const [metrics, setMetrics] = useState(["sales", "traffic", "conversion"]);
  const [result, setResult] = useState(null);
  const { invoke, isInvoking } = useToolInvocation("run-correlation-analysis");

  const runAnalysis = async () => {
    const res = await invoke({ dateRange, metrics });
    setResult(res.structuredContent);
  };

  return (
    <div className="p-6">
      <h1 className="text-2xl font-bold">📊 Retail Correlation Finder</h1>
      {/* Filter controls */}
      <div className="grid grid-cols-3 gap-4 my-4">
        <input type="date" value={dateRange.start} onChange={...} />
        <input type="date" value={dateRange.end} onChange={...} />
        <select multiple value={metrics} onChange={...}>
          <option value="sales">Penjualan</option>
          <option value="traffic">Traffic</option>
          <option value="conversion">Konversi</option>
          <option value="aov">AOV</option>
          <option value="cart_abandon">Cart Abandon</option>
        </select>
      </div>
      <button onClick={runAnalysis} disabled={isInvoking}>
        {isInvoking ? "⏳ Menganalisis..." : "🔍 Jalankan Analisis"}
      </button>
      {/* Heatmap korelasi */}
      {result && <CorrelationHeatmap matrix={result.matrix} insights={result.insights} />}
    </div>
  );
}

